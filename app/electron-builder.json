{
  "appId": "ai.openclaw.installer",
  "productName": "Claw Installer",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "electron-main.cjs",
    "preload.cjs",
    "package.json"
  ],
  "asar": true,
  "compression": "normal",
  "linux": {
    "target": ["AppImage", "tar.gz"],
    "category": "Utility"
  },
  "mac": {
    "target": ["dmg", "zip"]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      },
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Claw Installer"
  }
}
